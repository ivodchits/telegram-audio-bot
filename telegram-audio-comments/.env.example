# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Public HTTPS URL where this server is accessible
# In development, use ngrok: ngrok http 8080
# Example: https://abc123.ngrok-free.app
BASE_URL=https://your-domain.com

# Web server port
PORT=8080

# Context seconds before each comment in skip mode
CONTEXT_SECONDS=5

# Where session JSON and audio files are stored.
# Defaults to <repo>/telegram-audio-comments/data/ regardless of cwd.
# DATA_DIR=/var/lib/telegram-audio-comments

# Skip Telegram WebApp initData verification on API routes.
# ONLY for local development without a real bot token. NEVER set in production.
# DEV_MODE=true

# Max age (seconds) for initData replay protection. Default 24h.
# MAX_INIT_DATA_AGE_SECONDS=86400

# Reject incoming audio longer than this many seconds. Default 600 (10 min).
# MAX_AUDIO_SECONDS=600

# Reject incoming audio larger than this many megabytes. Default 25.
# MAX_AUDIO_MB=25

# Reject a single comment-recording upload larger than this many megabytes.
# Default 5.
# MAX_RECORDING_MB=5

# Delete sessions (and their audio files) older than this many days.
# Default 7.
# SESSION_TTL_DAYS=7

# How often the cleanup task runs (seconds). Default 3600 (hourly).
# CLEANUP_INTERVAL_SECONDS=3600

# Update delivery mode: "polling" (default) or "webhook".
# Polling uses long-poll getUpdates and works behind any NAT. Webhook needs a
# publicly-reachable HTTPS BASE_URL.
# MODE=polling

# Webhook path — keep it secret. Telegram will POST updates here.
# Convention: /tg/<random-hex>. Required when MODE=webhook.
# WEBHOOK_SECRET_PATH=/tg/REPLACE_ME_WITH_RANDOM_HEX

# Secret token Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token
# header on every webhook call. Generate with `python -c 'import secrets; print(secrets.token_hex(32))'`.
# Required when MODE=webhook.
# WEBHOOK_SECRET_TOKEN=REPLACE_ME_WITH_RANDOM_HEX

# ─── Comment transcription (Whisper) ──────────────────────────────────────
# Requires `pip install -r requirements-transcribe.txt`. When the package
# isn't installed, transcription is silently disabled and recordings ship
# without a transcript field — no need to flip the flag.

# Master switch. Default on; set to "false" to disable even when the wheel
# is installed.
# TRANSCRIBE_ENABLED=true

# Whisper model size: tiny, base, small, medium, large-v3. Bigger = slower
# but more accurate. "base" is the v1 default — runs on CPU for ~5-30s clips.
# WHISPER_MODEL=base

# Inference device: "cpu" or "cuda". CUDA needs a matching CTranslate2 build.
# WHISPER_DEVICE=cpu

# Quantization: int8 (cpu default), int8_float16, float16, float32. int8 is
# 2-4× faster on CPU with minimal accuracy loss for short comments.
# WHISPER_COMPUTE_TYPE=int8

# Force a transcription language (ISO-639-1, e.g. "en", "ru"). Leave unset
# to auto-detect per clip (~30% slower).
# WHISPER_LANGUAGE=

# Max simultaneous transcriptions. CTranslate2 CPU backends serialize cleanly
# at 1; raise only if you've moved to GPU.
# WHISPER_MAX_PARALLEL=1

# How long the stitch job waits for still-running transcriptions before
# snapshotting. Beyond this, recordings without a transcript ship blank.
# TRANSCRIBE_WAIT_SECONDS=10

# ─── Shutdown / runtime ───────────────────────────────────────────────────
# Seconds the process waits on SIGTERM/SIGINT for in-flight stitch jobs to
# finish before cancelling them. Set this above your worst-case stitch time;
# losing one mid-export corrupts the result file.
# SHUTDOWN_DRAIN_SECONDS=30

# How long a finished (done/error) stitch-job entry stays in memory before
# being evicted. The Mini App reads status during/just after stitching, so a
# few minutes is plenty.
# STITCH_JOB_TTL_SECONDS=300
